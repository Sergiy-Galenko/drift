{
  "expo": {
    "name": "Drift",
    "slug": "drift",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-drift.png",
    "backgroundColor": "#0A0A0A",
    "userInterfaceStyle": "dark",
    "scheme": "drift",
    "splash": {
      "backgroundColor": "#0A0A0A",
      "resizeMode": "contain"
    },
    "ios": {
      "bundleIdentifier": "com.drift.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Drift needs access to upload proof of your completed commitments.",
        "NSCameraUsageDescription": "Drift needs camera access to capture proof."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.drift.app",
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Drift needs access to upload proof of your completed commitments.",
          "cameraPermission": "Drift needs camera access to capture proof."
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
