rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }
    function onlyVoteFields(req) {
      return req.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['votesYes', 'votesNo', 'voters', 'viewCount', 'shareCount']);
    }
    function onlyProofFields(req) {
      return req.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['proofUrl', 'proofType', 'proofUploadedAt', 'status']);
    }

    match /drifts/{driftId} {
      allow read: if true;
      allow create: if isAuthenticated()
                    && request.resource.data.authorUid == request.auth.uid
                    && request.resource.data.text.size() <= 200
                    && request.resource.data.stake.size() <= 100;
      allow update: if isAuthenticated() && (
        isOwner(resource.data.authorUid)
        || onlyVoteFields(request)
        || onlyProofFields(request)
      );
      allow delete: if false;
    }

    match /comments/{driftId}/messages/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated()
                    && request.resource.data.authorUid == request.auth.uid
                    && request.resource.data.text.size() <= 280;
      allow update: if isAuthenticated() && (
        isOwner(resource.data.authorUid) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'likedBy'])
      );
      allow delete: if isOwner(resource.data.authorUid);
    }

    match /users/{uid} {
      allow read: if true;
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    match /bookmarks/{uid}/items/{driftId} {
      allow read, write: if isOwner(uid);
    }

    match /follows/{followDoc} {
      allow read: if true;
      allow create: if isAuthenticated()
                    && request.resource.data.followerId == request.auth.uid;
      allow delete: if isAuthenticated()
                    && resource.data.followerId == request.auth.uid;
    }

    match /notifications/{uid}/items/{itemId} {
      allow read, write: if isOwner(uid);
    }

    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read: if false;
    }

    match /trending/{period} {
      allow read: if true;
      allow write: if false;
    }
  }
}
